# E-commerce CX Chatbot — Environment Variables

GOOGLE_API_KEY=...
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Mock API Service
MOCK_API_BASE_URL=http://localhost:8100

# SQLite Database for chat memory
SQLITE_DB_PATH=chatbot_memory.db

# Unified service port (chatbot + WhatsApp webhook)
CHATBOT_PORT=8000

# WhatsApp Integration (optional — only needed when receiving WhatsApp messages)
WHATSAPP_VERIFY_TOKEN=...
WHATSAPP_ACCESS_TOKEN=...
WHATSAPP_PHONE_NUMBER_ID=...

# Shopify + Clickpost credentials (chat_service tenants, e.g. nobero)
SHOPIFY_SHOP_NAME=xxx.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxx
CLICKPOST_USERNAME=username
CLICKPOST_API_KEY=key
ORDERS_MONTHS_LIMIT=6
